# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# SQLite dev databases
dev.db
dev.db-shm
dev.db-wal

# Large extracted data (regenerable via scripts)
data/extracted/*.json

# Prototype data (55MB compiled JS)
prototype/sr_homeopata_data.js

# Claude local settings
.claude/settings.local.json

# Materia medica cache and exports
data/cache/
data/export-*.csv
data/export-*.sql

# ═══════════════════════════════════
# SECURITY — Prevent credential leaks
# ═══════════════════════════════════

# Environment and secrets
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.der
*.jks
id_rsa*
*.secret

# Docker secrets
docker-compose.override.yml
docker-compose.prod.yml

# Backup files (may contain sensitive data)
*.bak
*.backup
*.dump
*.sql.gz
*.tar.gz

# IDE and editor files
.idea/
.vscode/settings.json
.vscode/launch.json
*.swp
*.swo
*~

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini
.Spotlight-V100
.Trashes

# Log files
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# Database files
*.sqlite
*.sqlite3
*.db

# Credential files
credentials.json
service-account*.json
firebase*.json
google-cloud*.json
