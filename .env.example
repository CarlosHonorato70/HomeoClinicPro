# =============================================================================
# HomeoClinic Pro — Environment Variables
# =============================================================================
# Copy this file to .env (dev) or .env.production (Docker deploy)

# ===== Database (PostgreSQL) =====
DATABASE_URL="postgresql://postgres:CHANGE_ME@db:5432/homeoclinic"
DIRECT_URL="postgresql://postgres:CHANGE_ME@db:5432/homeoclinic"

# ===== NextAuth =====
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Production URL (e.g. https://homeoclinic.pro)
NEXTAUTH_URL="http://localhost:3000"

# ===== Encryption (LGPD - AES-256-GCM) =====
# 32 bytes = 64 hex chars. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# ===== Stripe (Payments) =====
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
# Webhook secret: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=""
# Price IDs: https://dashboard.stripe.com/products
STRIPE_PRICE_PROFESSIONAL=""
STRIPE_PRICE_ENTERPRISE=""

# ===== Email (Brevo / ex-Sendinblue) =====
# Get API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=""
EMAIL_FROM="HomeoClinic Pro <noreply@seudominio.com>"

# ===== Redis Rate Limiting (optional) =====
# Docker: redis://redis:6379
# Upstash: use UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN
# If not set, falls back to in-memory rate limiting
REDIS_URL=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ===== Error Monitoring (Sentry — optional) =====
# Get from: https://sentry.io/settings/projects/
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ===== Docker Compose (PostgreSQL credentials) =====
POSTGRES_DB="homeoclinic"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="CHANGE_ME_STRONG_PASSWORD"

# ===== Deployment =====
NODE_ENV="production"
