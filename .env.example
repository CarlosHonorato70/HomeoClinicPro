# =============================================================================
# HomeoClinic Pro — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# ===== Database (PostgreSQL) =====
# Pooled connection (via PgBouncer / Supabase pooler on port 6543)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (for migrations, on port 5432)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# ===== NextAuth =====
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=""
# Production URL (e.g. https://homeoclinic.pro)
NEXTAUTH_URL="http://localhost:3000"

# ===== Encryption (LGPD - AES-256-GCM) =====
# 32 bytes = 64 hex chars. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# ===== Stripe (Payments) =====
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
# Webhook secret: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=""
# Price IDs: https://dashboard.stripe.com/products
STRIPE_PRICE_PROFESSIONAL=""
STRIPE_PRICE_ENTERPRISE=""

# ===== Email (Resend) =====
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="HomeoClinic Pro <noreply@yourdomain.com>"

# ===== Redis Rate Limiting (Upstash — optional) =====
# Get from: https://console.upstash.com
# If not set, falls back to in-memory rate limiting
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ===== Error Monitoring (Sentry — optional) =====
# Get from: https://sentry.io/settings/projects/
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ===== Deployment =====
NODE_ENV="development"
